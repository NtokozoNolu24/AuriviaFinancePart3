<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="8dp"
    app:cardBackgroundColor="#1E1E1E"
    app:cardCornerRadius="8dp"
    app:cardElevation="2dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="12dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <View
                android:id="@+id/viewColor"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:background="#E040FB" />

            <TextView
                android:id="@+id/tvCategoryName"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="12dp"
                android:text="Category Name"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                tools:text="Groceries" />

            <TextView
                android:id="@+id/tvBudgetAmount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="R0.00"
                android:textColor="#E040FB"
                android:textSize="16sp"
                android:textStyle="bold"
                tools:text="R1,000.00" />
        </LinearLayout>

        <ProgressBar
            android:id="@+id/progressCategory"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="match_parent"
            android:layout_height="8dp"
            android:layout_marginTop="8dp"
            android:max="100"
            android:progress="0"
            android:progressTint="#E040FB"
            android:progressBackgroundTint="#3D3D3D" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/tvSpent"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Spent: R0.00"
                android:textColor="#CE93D8"
                android:textSize="12sp"
                tools:text="Spent: R450.00" />

            <TextView
                android:id="@+id/tvRemaining"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Remaining: R0.00"
                android:textColor="#CE93D8"
                android:textSize="12sp"
                tools:text="Remaining: R550.00" />
        </LinearLayout>
    </LinearLayout>
</androidx.cardview.widget.CardView>