<?xml version="1.0" encoding="utf-8"?>

<androidx.constraintlayout.widget.ConstraintLayout

    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"


    android:layout_width="match_parent"

    android:layout_height="match_parent"


    android:background="#F5F7F5"


    android:padding="16dp">





    <!-- TITLE -->

    <TextView

        android:id="@+id/tvExpensesTitle"

        android:layout_width="wrap_content"

        android:layout_height="wrap_content"


        android:text="💰 Expenses"

        android:textSize="28sp"

        android:textStyle="bold"

        android:textColor="#1B5E20"


        app:layout_constraintStart_toStartOf="parent"

        app:layout_constraintTop_toTopOf="parent"/>






    <TextView

        android:id="@+id/tvExpensesSubtitle"

        android:layout_width="wrap_content"

        android:layout_height="wrap_content"


        android:text="Track your spending and build better habits"

        android:textSize="14sp"

        android:textColor="#757575"


        android:layout_marginTop="6dp"


        app:layout_constraintStart_toStartOf="parent"

        app:layout_constraintTop_toBottomOf="@id/tvExpensesTitle"/>








    <!-- ADD BUTTON -->


    <com.google.android.material.floatingactionbutton.FloatingActionButton


        android:id="@+id/fabAddExpense"


        android:layout_width="wrap_content"

        android:layout_height="wrap_content"


        android:layout_margin="20dp"


        android:contentDescription="Add Expense"


        android:src="@drawable/ic_add"


        app:backgroundTint="#2E7D32"


        app:tint="#FFFFFF"


        app:layout_constraintBottom_toBottomOf="parent"


        app:layout_constraintEnd_toEndOf="parent"/>









    <!-- FILTER CARD -->


    <com.google.android.material.card.MaterialCardView


        android:id="@+id/cardFilters"


        android:layout_width="match_parent"


        android:layout_height="wrap_content"


        android:layout_marginTop="20dp"


        app:cardCornerRadius="20dp"


        app:cardElevation="4dp"


        app:cardBackgroundColor="#FFFFFF"


        app:layout_constraintTop_toBottomOf="@id/tvExpensesSubtitle"


        app:layout_constraintStart_toStartOf="parent"

        app:layout_constraintEnd_toEndOf="parent">






        <LinearLayout


            android:layout_width="match_parent"


            android:layout_height="wrap_content"


            android:orientation="vertical"


            android:padding="18dp">






            <TextView


                android:layout_width="wrap_content"


                android:layout_height="wrap_content"


                android:text="🔎 Filter Expenses"


                android:textSize="18sp"


                android:textStyle="bold"


                android:textColor="#1B5E20"/>







            <LinearLayout


                android:layout_width="match_parent"


                android:layout_height="wrap_content"


                android:layout_marginTop="12dp"


                android:orientation="horizontal">






                <Spinner


                    android:id="@+id/spinnerCategory"


                    android:layout_width="0dp"


                    android:layout_height="45dp"


                    android:layout_weight="1"


                    android:background="@drawable/spinner_background_purple"/>







                <Spinner


                    android:id="@+id/spinnerDate"


                    android:layout_width="0dp"


                    android:layout_height="45dp"


                    android:layout_weight="1"


                    android:layout_marginStart="10dp"


                    android:background="@drawable/spinner_background_purple"/>







            </LinearLayout>







            <Button


                android:id="@+id/btnApplyFilters"


                android:layout_width="match_parent"


                android:layout_height="48dp"


                android:layout_marginTop="14dp"


                android:text="Apply Filters"


                android:textColor="#FFFFFF"


                android:textStyle="bold"


                android:background="@drawable/rounded_button_green"/>






        </LinearLayout>






    </com.google.android.material.card.MaterialCardView>









    <!-- EXPENSE LIST -->


    <androidx.recyclerview.widget.RecyclerView


        android:id="@+id/rvExpenses"


        android:layout_width="match_parent"


        android:layout_height="0dp"


        android:layout_marginTop="16dp"


        app:layout_constraintTop_toBottomOf="@id/cardFilters"


        app:layout_constraintBottom_toBottomOf="parent"


        app:layout_constraintStart_toStartOf="parent"


        app:layout_constraintEnd_toEndOf="parent"


        tools:listitem="@layout/item_expense"/>








    <!-- EMPTY MESSAGE -->


    <TextView


        android:id="@+id/tvNoExpenses"


        android:layout_width="wrap_content"


        android:layout_height="wrap_content"


        android:text="📭 No expenses yet\nStart tracking your money!"


        android:gravity="center"


        android:textSize="16sp"


        android:textColor="#757575"


        android:visibility="gone"


        app:layout_constraintTop_toBottomOf="@id/cardFilters"


        app:layout_constraintBottom_toBottomOf="parent"


        app:layout_constraintStart_toStartOf="parent"


        app:layout_constraintEnd_toEndOf="parent"/>





</androidx.constraintlayout.widget.ConstraintLayout>